import std/test { assert, assert_msg, assert_eq_int, assert_eq_str, assert_eq_float }
import std/string
import "./resp" { _encode, _parse_at, Value, _ParseResult }

// --- Encoder ---

fun test_encode_single() {
    assert_eq_str(_encode(["PING"]), "*1\r\n$4\r\nPING\r\n")
}

fun test_encode_multi() {
    assert_eq_str(_encode(["SET", "k", "v"]), "*3\r\n$3\r\nSET\r\n$1\r\nk\r\n$1\r\nv\r\n")
}

// Argument containing CRLF must be length-prefixed verbatim (binary-safe).
fun test_encode_binary_arg() {
    assert_eq_str(_encode(["SET", "k", "a\r\nb"]), "*3\r\n$3\r\nSET\r\n$1\r\nk\r\n$4\r\na\r\nb\r\n")
}

// --- Parser: scalars ---

fun test_parse_simple() {
    match _parse_at("+OK\r\n", 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 5)
            match v {
                Simple(s) -> assert_eq_str(s, "OK"),
                _ -> assert_msg(false, "expected Simple"),
            }
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_error() {
    match _parse_at("-ERR bad\r\n", 0) {
        Complete(v, np) -> match v {
            Error(s) -> assert_eq_str(s, "ERR bad"),
            _ -> assert_msg(false, "expected Error"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_int() {
    match _parse_at(":1000\r\n", 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 7)
            match v {
                Int(n) -> assert_eq_int(n, 1000),
                _ -> assert_msg(false, "expected Int"),
            }
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

// --- Parser: bulk strings ---

fun test_parse_bulk() {
    match _parse_at("$6\r\nfoobar\r\n", 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 12)
            match v {
                Bulk(s) -> assert_eq_str(s, "foobar"),
                _ -> assert_msg(false, "expected Bulk"),
            }
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_bulk_empty() {
    match _parse_at("$0\r\n\r\n", 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 6)
            match v {
                Bulk(s) -> assert_eq_str(s, ""),
                _ -> assert_msg(false, "expected empty Bulk"),
            }
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_null_bulk() {
    match _parse_at("$-1\r\n", 0) {
        Complete(v, np) -> assert(v.is_null()),
        _ -> assert_msg(false, "expected Complete Null"),
    }
}

// Bulk payload containing CRLF: must be read by exact length, binary-safe.
fun test_parse_bulk_binary() {
    match _parse_at("$4\r\na\r\nb\r\n", 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 10)
            match v {
                Bulk(s) -> {
                    assert_eq_int(s.len(), 4)
                    assert_eq_str(s, "a\r\nb")
                },
                _ -> assert_msg(false, "expected Bulk"),
            }
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

// --- Parser: arrays ---

fun test_parse_array() {
    match _parse_at("*2\r\n$3\r\nfoo\r\n:42\r\n", 0) {
        Complete(v, np) -> match v {
            Array(xs) -> {
                assert_eq_int(xs.len(), 2)
            },
            _ -> assert_msg(false, "expected Array"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_array_null() {
    match _parse_at("*-1\r\n", 0) {
        Complete(v, np) -> assert(v.is_null()),
        _ -> assert_msg(false, "expected Complete Null"),
    }
}

fun test_parse_array_empty() {
    match _parse_at("*0\r\n", 0) {
        Complete(v, np) -> match v {
            Array(xs) -> assert_eq_int(xs.len(), 0),
            _ -> assert_msg(false, "expected empty Array"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

// --- Partial reads (the core correctness property) ---

fun test_incomplete_header() {
    match _parse_at("$6\r\nfoo", 0) {
        Incomplete -> assert(true),
        _ -> assert_msg(false, "expected Incomplete (body not fully arrived)"),
    }
}

fun test_split_buffer_then_complete() {
    let full = "$6\r\nfoobar\r\n"
    // Feed only a prefix: parser must report Incomplete, never block or guess.
    match _parse_at(full.substring(0, 7), 0) {
        Incomplete -> assert(true),
        _ -> assert_msg(false, "expected Incomplete on split buffer"),
    }
    // Once the rest arrives, the same parser yields the full value.
    match _parse_at(full, 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 12)
            match v {
                Bulk(s) -> assert_eq_str(s, "foobar"),
                _ -> assert_msg(false, "expected Bulk"),
            }
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

// --- RESP3 scalar types ---

fun test_parse_resp3_null() {
    match _parse_at("_\r\n", 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 3)
            assert(v.is_null())
        },
        _ -> assert_msg(false, "expected Complete Null"),
    }
}

fun test_parse_bool_true() {
    match _parse_at("#t\r\n", 0) {
        Complete(v, np) -> match v {
            Bool(b) -> assert(b),
            _ -> assert_msg(false, "expected Bool"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_bool_false() {
    match _parse_at("#f\r\n", 0) {
        Complete(v, np) -> match v {
            Bool(b) -> assert(b == false),
            _ -> assert_msg(false, "expected Bool"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_double() {
    match _parse_at(",3.14\r\n", 0) {
        Complete(v, np) -> match v {
            Double(d) -> assert_eq_float(d, 3.14, 0.001),
            _ -> assert_msg(false, "expected Double"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_big_number() {
    match _parse_at("(12345678901234567890\r\n", 0) {
        Complete(v, np) -> match v {
            BigNumber(s) -> assert_eq_str(s, "12345678901234567890"),
            _ -> assert_msg(false, "expected BigNumber"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_blob_error() {
    // "!" + length-framed error message "ERR foobar" (10 bytes).
    match _parse_at("!10\r\nERR foobar\r\n", 0) {
        Complete(v, np) -> match v {
            Error(s) -> assert_eq_str(s, "ERR foobar"),
            _ -> assert_msg(false, "expected Error"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_verbatim() {
    // "txt:Some string" is 15 bytes: fmt "txt", text "Some string".
    match _parse_at("=15\r\ntxt:Some string\r\n", 0) {
        Complete(v, np) -> {
            assert_eq_int(np, 22)
            match v {
                Verbatim(f, t) -> {
                    assert_eq_str(f, "txt")
                    assert_eq_str(t, "Some string")
                },
                _ -> assert_msg(false, "expected Verbatim"),
            }
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

// --- RESP3 aggregate types ---

fun test_parse_map() {
    // %1 -> one pair -> two elements (k, v).
    match _parse_at("%1\r\n$1\r\nk\r\n$1\r\nv\r\n", 0) {
        Complete(v, np) -> match v {
            Map(xs) -> assert_eq_int(xs.len(), 2),
            _ -> assert_msg(false, "expected Map"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_set() {
    match _parse_at("~2\r\n:1\r\n:2\r\n", 0) {
        Complete(v, np) -> match v {
            Set(xs) -> assert_eq_int(xs.len(), 2),
            _ -> assert_msg(false, "expected Set"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

fun test_parse_push() {
    match _parse_at(">1\r\n$3\r\nfoo\r\n", 0) {
        Complete(v, np) -> match v {
            Push(xs) -> assert_eq_int(xs.len(), 1),
            _ -> assert_msg(false, "expected Push"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

// Attributes precede the real value and must be consumed, then skipped.
fun test_parse_attribute_skipped() {
    match _parse_at("|1\r\n$3\r\nkey\r\n$3\r\nval\r\n:25\r\n", 0) {
        Complete(v, np) -> match v {
            Int(n) -> assert_eq_int(n, 25),
            _ -> assert_msg(false, "expected the Int that follows the attribute"),
        },
        _ -> assert_msg(false, "expected Complete"),
    }
}

// Partial-read handling must still hold for RESP3 aggregates.
fun test_parse_map_incomplete() {
    match _parse_at("%1\r\n$1\r\nk\r\n", 0) {
        Incomplete -> assert(true),
        _ -> assert_msg(false, "expected Incomplete (map value missing)"),
    }
}
