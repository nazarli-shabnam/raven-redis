// Integration tests — exercised against a live Redis at ADDR.
//
// They are GATED on reachability: if no server is listening, they skip
// (so `rvpm test` stays green offline; the protocol itself is covered by the
// network-free unit tests in resp_test.rv). Bring a server up with:
//   docker run --rm -p 6379:6379 redis:7
//
// Safety: tests use the `rrtest:` key prefix and clean up only those keys.
// They never call FLUSHDB, so pointing at a real server will not wipe data.

import std/test { assert, assert_msg, assert_eq_int, assert_eq_str }
import std/net { reachable }
import "./lib" { connect, connect_opts, ConnectOptions, Client, MessageKind }
import "./resp" { Value }

const ADDR: String = "127.0.0.1:6379"

fun test_integration_suite() {
    if reachable(ADDR) {
        match _run(ADDR) {
            Ok(_) -> assert(true),
            Err(e) -> assert_msg(false, e.message),
        }
    }
}

fun test_resp3_suite() {
    if reachable(ADDR) {
        match _run_resp3() {
            Ok(_) -> assert(true),
            Err(e) -> assert_msg(false, e.message),
        }
    }
}

// RESP3-specific reply types, verified against a live RESP3-capable server.
fun _run_resp3() -> Result<Bool, Error> {
    let opts = ConnectOptions.new("127.0.0.1", 6379).resp3(true)
    let c = connect_opts(opts)?

    c.del(["rrtest:h", "rrtest:set"])?

    // HGETALL returns a Map in RESP3 (2 fields -> 4 flat elements).
    c.command(["HSET", "rrtest:h", "f1", "v1", "f2", "v2"])?
    match c.command(["HGETALL", "rrtest:h"])? {
        Map(xs) -> assert_eq_int(xs.len(), 4),
        _ -> assert_msg(false, "expected Map from HGETALL in RESP3"),
    }

    // SMEMBERS returns a Set in RESP3.
    c.command(["SADD", "rrtest:set", "a", "b", "c"])?
    match c.command(["SMEMBERS", "rrtest:set"])? {
        Set(xs) -> assert_eq_int(xs.len(), 3),
        _ -> assert_msg(false, "expected Set from SMEMBERS in RESP3"),
    }

    // Membership check: some servers reply with a RESP3 Bool, others still
    // with an Int (1/0). Accept either — Bool parsing is covered by unit tests.
    match c.command(["SISMEMBER", "rrtest:set", "a"])? {
        Bool(b) -> assert(b),
        Int(n) -> assert_eq_int(n, 1),
        _ -> assert_msg(false, "expected Bool or Int from SISMEMBER"),
    }

    c.del(["rrtest:h", "rrtest:set"])?
    c.close()
    return Ok(true)
}

// The whole flow as one Result-returning routine so we can use `?`.
fun _run(addr: String) -> Result<Bool, Error> {
    let c = connect(addr)?

    // Start clean (targeted, never FLUSHDB).
    c.del(
        [
            "rrtest:k",
            "rrtest:bin",
            "rrtest:n",
            "rrtest:str",
            "rrtest:a",
            "rrtest:m1",
            "rrtest:m2",
            "rrtest:nx",
            "rrtest:cnt",
        ],
    )?

    // PING
    assert_eq_str(c.ping()?, "PONG")

    // SET / GET roundtrip
    c.set("rrtest:k", "v")?
    match c.get("rrtest:k")? {
        Some(s) -> assert_eq_str(s, "v"),
        None -> assert_msg(false, "expected value for rrtest:k"),
    }

    // Missing key -> None
    match c.get("rrtest:missing")? {
        Some(_x) -> assert_msg(false, "expected None for missing key"),
        None -> assert(true),
    }

    // Binary-safe value: contains CRLF and a NUL byte.
    c.set("rrtest:bin", "a\r\n\0b")?
    match c.get("rrtest:bin")? {
        Some(s) -> {
            assert_eq_int(s.len(), 5)
            assert_eq_str(s, "a\r\n\0b")
        },
        None -> assert_msg(false, "expected value for rrtest:bin"),
    }

    // INCR
    c.set("rrtest:n", "10")?
    assert_eq_int(c.incr("rrtest:n")?, 11)

    // DEL count
    assert_eq_int(c.del(["rrtest:k", "rrtest:n"])?, 2)

    // A Redis error reply surfaces as Err (WRONGTYPE).
    c.set("rrtest:str", "x")?
    match c.command(["LPUSH", "rrtest:str", "y"]) {
        Ok(_v) -> assert_msg(false, "expected WRONGTYPE error"),
        Err(_e) -> assert(true),
    }

    // Pipeline: three commands, three replies.
    let replies = c.pipeline([["SET", "rrtest:a", "1"], ["INCR", "rrtest:a"], ["GET", "rrtest:a"]])?
    assert_eq_int(replies.len(), 3)

    // --- v0.2.0 helpers ---
    // MSET / MGET (missing key -> None)
    c.mset([["rrtest:m1", "x"], ["rrtest:m2", "y"]])?
    let vals = c.mget(["rrtest:m1", "rrtest:m2", "rrtest:missing"])?
    assert_eq_int(vals.len(), 3)
    let somes = 0
    let nones = 0
    for o in vals {
        match o {
            Some(_s) -> {
                somes = somes + 1
            },
            None -> {
                nones = nones + 1
            },
        }
    }
    assert_eq_int(somes, 2)
    assert_eq_int(nones, 1)

    // SET NX: first stores, second is rejected.
    assert(c.set_nx("rrtest:nx", "1")?)
    if c.set_nx("rrtest:nx", "2")? {
        assert_msg(false, "set_nx should fail on an existing key")
    }

    // INCRBY
    c.set("rrtest:cnt", "10")?
    assert_eq_int(c.incr_by("rrtest:cnt", 5)?, 15)

    // TYPE
    assert_eq_str(c.type_of("rrtest:m1")?, "string")

    // KEYS / SCAN see our prefixed keys.
    let found = c.keys("rrtest:*")?
    assert(found.len() >= 1)
    let sr = c.scan(0, "rrtest:*", 100)?
    assert(sr.cursor >= 0)

    // Final cleanup.
    c.del(
        [
            "rrtest:bin",
            "rrtest:str",
            "rrtest:a",
            "rrtest:m1",
            "rrtest:m2",
            "rrtest:nx",
            "rrtest:cnt",
        ],
    )?
    c.close()
    return Ok(true)
}

fun test_pubsub_suite() {
    if reachable(ADDR) {
        match _run_pubsub() {
            Ok(_) -> assert(true),
            Err(e) -> assert_msg(false, e.message),
        }
    }
}

// Pub/Sub end-to-end: a publisher plus dedicated subscriber connections, over
// both RESP2 and RESP3, including pattern subscriptions. Subscribers use a read
// timeout so a missing message fails the test instead of hanging.
fun _run_pubsub() -> Result<Bool, Error> {
    let pub = connect(ADDR)?

    // No subscribers yet -> 0 receivers.
    assert_eq_int(pub.publish("rrtest:chan", "x")?, 0)

    // RESP2 subscriber.
    let sub = connect_opts(ConnectOptions.new("127.0.0.1", 6379).read_timeout_ms(3000))?
    sub.subscribe(["rrtest:chan"])?
    assert_eq_int(pub.publish("rrtest:chan", "hello")?, 1)
    let m = sub.next_message()?
    match m.kind {
        Message -> {
            assert_eq_str(m.channel, "rrtest:chan")
            assert_eq_str(m.payload, "hello")
        },
        _ -> assert_msg(false, "expected a Message"),
    }
    sub.unsubscribe(["rrtest:chan"])?
    sub.close()

    // RESP3 subscriber (messages arrive as Push frames).
    let sub3 = connect_opts(ConnectOptions.new("127.0.0.1", 6379).resp3(true).read_timeout_ms(3000))?
    sub3.subscribe(["rrtest:chan"])?
    assert_eq_int(pub.publish("rrtest:chan", "world")?, 1)
    let m3 = sub3.next_message()?
    assert_eq_str(m3.payload, "world")
    sub3.close()

    // Pattern subscription.
    let psub = connect_opts(ConnectOptions.new("127.0.0.1", 6379).read_timeout_ms(3000))?
    psub.psubscribe(["rrtest:*"])?
    assert_eq_int(pub.publish("rrtest:news", "p")?, 1)
    let pm = psub.next_message()?
    match pm.kind {
        PMessage -> {
            assert_eq_str(pm.pattern, "rrtest:*")
            assert_eq_str(pm.channel, "rrtest:news")
            assert_eq_str(pm.payload, "p")
        },
        _ -> assert_msg(false, "expected a PMessage"),
    }
    psub.close()

    pub.close()
    return Ok(true)
}
